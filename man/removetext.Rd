\name{removetext}
\alias{removetext}
\title{Remove the first literal match}
\usage{
removetext(x, pattern)
}
\arguments{
\item{x}{A character vector or factor.}

\item{pattern}{A literal substring to remove.}
}
\value{
A character vector with the first matching substring removed.
}
\description{
Remove the first occurrence of a literal substring from each element.
}

\name{compare}
\alias{compare}
\title{Compare tables}
\usage{
compare(x, y, by = NULL)
}
\arguments{
\item{x, y}{Data frames or data tables to compare.}

\item{by}{Optional key columns for overlap checks.}
}
\value{
A list of comparison tables.
}
\description{
Compare dimensions, names, types, missingness, and key overlap for two
tables.
}

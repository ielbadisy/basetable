\name{headtail}
\alias{headtail}
\title{Head and tail rows}
\usage{
headtail(data, n = 3)
}
\arguments{
\item{data}{A data frame or data table.}

\item{n}{Number of rows to show from the start and end.}
}
\value{
A tibble containing the selected rows.
}
\description{
Return the first and last `n` rows of a table.
}

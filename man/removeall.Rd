\name{removeall}
\alias{removeall}
\title{Remove all literal matches}
\usage{
removeall(x, pattern)
}
\arguments{
\item{x}{A character vector or factor.}

\item{pattern}{A literal substring to remove.}
}
\value{
A character vector with all matching substrings removed.
}
\description{
Remove every occurrence of a literal substring from each element.
}
